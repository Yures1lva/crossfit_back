# ═══════════════════════════════════════════════════
# CrossFit Arena — Variáveis de Ambiente
# ═══════════════════════════════════════════════════
# Copie para .env e preencha os valores.
# Em PRODUÇÃO (Render), configurar direto no dashboard.

# ── Banco de Dados ────────────────────────────────
# DEV: PostgreSQL local
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha
DB_NAME=crossfit_arena

# PROD: Supabase (preencher no Render)
# DB_HOST=aws-1-sa-east-1.pooler.supabase.com
# DB_PORT=5432
# DB_USER=postgres.xxxxxxxxxxxxxxxx
# DB_PASSWORD=xxxxx
# DB_NAME=postgres

# ── JWT ───────────────────────────────────────────
JWT_ACCESS_SECRET=crossfit_access_secret_CHANGE_ME
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=crossfit_refresh_secret_CHANGE_ME
JWT_REFRESH_EXPIRES_IN=7d

# ── App ───────────────────────────────────────────
PORT=3004
NODE_ENV=development
DOMAIN=localhost

# ── Pool ──────────────────────────────────────────
DB_POOL_MIN=1
DB_POOL_MAX=10

# ── Storage ───────────────────────────────────────
# local = disco local (dev), supabase = Supabase Storage (prod)
STORAGE_DRIVER=local
# SUPABASE_URL=https://xxxxxxxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJhbG...

# ── CORS / Cookies ────────────────────────────────
FRONTEND_URL=http://localhost:3000
# Em produção: FRONTEND_URL=https://sooacosports.com.br
COOKIE_DOMAIN=
# Em produção: COOKIE_DOMAIN=.sooacosports.com.br
# (o ponto inicial abrange subdomínios: api.sooacosports.com.br, app.sooacosports.com.br)
